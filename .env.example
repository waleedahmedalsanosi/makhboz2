# Copy this file to .env.local and fill in the values
# NEVER commit .env.local — it's blocked by .gitignore

# PostgreSQL from neon.tech — use the "Pooled connection" string
# Must include ?sslmode=require at the end
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/makhboz?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="your-random-64-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary — from cloudinary.com dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
